      - uses: actions/setup-java@1bcf9fb12cf4aa7d266a90ae39939e61372fe520 # v5.4.0
        with:
          distribution: temurin
          java-version: "{{ java_version }}"
      - run: ./gradlew build test
      # Diff coverage gates PRs only. On a push to main, github.base_ref is empty
      # and origin/main == HEAD, so the diff would be empty and the gate a no-op —
      # gate the PR, where the base branch is a real, different ref.
      - name: Diff coverage
        if: {% raw %}${{ github.event_name == 'pull_request' }}{% endraw %}
        env:
          BASE_REF: {% raw %}${{ github.base_ref }}{% endraw %}
        run: |
          report=build/reports/jacoco/test/jacocoTestReport.xml
          [ -f "$report" ] || report=target/site/jacoco/jacoco.xml
          pipx run diff-cover "$report" --compare-branch="origin/$BASE_REF" --fail-under=100
