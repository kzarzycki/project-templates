{% include "templates/_base/_ci_header.yml.jinja" %}
jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      # setup-* only install binaries — no repo needed yet, so they run before
      # the shared checkout/pre-commit block. The terraform_fmt + terraform_tflint
      # hooks then find both tools on PATH.
      - uses: hashicorp/setup-terraform@dfe3c3f87815947d99a8997f908cb6525fc44e9e # v4.0.1
        with:
          terraform_version: "{{ terraform_version }}"
          terraform_wrapper: false
      - uses: terraform-linters/setup-tflint@6e1e0642c0289bd619021bf6b34e3c08ed1e005a # v6.3.0
{% include "templates/_base/_ci_steps.yml.jinja" %}
      - name: terraform validate
        run: |
          terraform init -backend=false -input=false
          terraform validate
